{
  "name": "@nirapod-audit/workspace",
  "private": true,
  "description": "Custom rules-based audit toolchain for Nirapod repos. Point it at any project, lib, or codebase and it tells you what's wrong.",
  "keywords": ["nirapod", "audit", "toolchain", "code-quality", "static-analysis", "typescript", "linting"],
  "workspaces": [
    "packages/protocol",
    "packages/core",
    "apps/cli"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "audit": "bun run apps/cli/src/index.tsx",
    "dev": "bun run --filter '@nirapod-audit/cli' dev"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "typescript": "^6.0.2"
  }
}
